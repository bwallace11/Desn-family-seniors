---
const { name, image, favorite_emoji, bio, github_permalink, github_profile, codepen_profile } = Astro.props;
const tapeSources = [
  "/images/tape/blktape2.png",
  "/images/tape/blktape3.png",
  "/images/tape/redtape1.png",
  "/images/tape/redtape2.png",
  "/images/tape/redtape3.png",
  "/images/tape/whttape1.png",
  "/images/tape/whttape2.png",
  "/images/tape/whttape3.png",
];
const tapeIndex = name.length % tapeSources.length;
const tapeLeft = tapeSources[tapeIndex];
const tapeRight = tapeSources[(tapeIndex + 3) % tapeSources.length];
const paperSources = ["/images/paper/tornPaper1.png"];
const edgeClips = [
  "polygon(1% 2%, 98% 0%, 99% 9%, 97% 18%, 99% 26%, 98% 36%, 99% 47%, 97% 57%, 98% 66%, 99% 77%, 97% 88%, 99% 98%, 2% 99%, 0% 88%, 1% 78%, 0% 68%, 2% 58%, 1% 48%, 2% 36%, 1% 26%, 2% 16%)",
  "polygon(2% 1%, 97% 2%, 99% 12%, 97% 22%, 98% 32%, 96% 42%, 98% 52%, 96% 62%, 98% 72%, 96% 82%, 98% 92%, 97% 99%, 4% 98%, 1% 92%, 2% 82%, 0% 72%, 2% 62%, 1% 52%, 2% 42%, 1% 32%, 2% 22%)",
  "polygon(0% 4%, 98% 1%, 99% 10%, 97% 20%, 99% 30%, 97% 40%, 99% 50%, 97% 60%, 99% 70%, 97% 80%, 99% 90%, 98% 99%, 6% 98%, 1% 94%, 2% 84%, 0% 74%, 2% 64%, 1% 54%, 2% 44%, 1% 34%, 2% 24%)",
  "polygon(1% 3%, 99% 2%, 97% 13%, 99% 23%, 97% 33%, 99% 43%, 97% 53%, 99% 63%, 97% 73%, 99% 83%, 97% 93%, 96% 99%, 3% 98%, 1% 92%, 2% 82%, 0% 72%, 2% 62%, 1% 52%, 2% 42%, 1% 32%, 2% 22%)",
];
const hash = [...name].reduce(
  (acc, char) => (acc * 31 + char.charCodeAt(0)) % 100000,
  0,
);
const paperPrimary = paperSources[hash % paperSources.length];
const edgeClip = edgeClips[hash % edgeClips.length];
---

<section class="student">
  <figure
    class="student-poster"
    style={`--tape-left: url('${tapeLeft}'); --tape-right: url('${tapeRight}');`}
  >
    <div class="student-photo" style={`--edge-clip: ${edgeClip};`}>
      <img src={image} alt={name} loading="lazy" />
    </div>
    <a class="student-back" href="/">Back to wall</a>
  </figure>
  <div
    class="student-bio-panel"
    style={`--bio-paper: url('${paperPrimary}'); --bio-paper-size: 120% 120%;`}
    aria-label={`${name} bio`}
  >
    <div class="student-bio-header">
      <h1>
        <span class="student-emoji" aria-hidden="true">{favorite_emoji}</span>
        {name}
      </h1>
    </div>
    <p>{bio}</p>
    <nav class="student-links" aria-label={`${name} links`}>
      {github_permalink && (
        <a href={github_permalink} target="_blank" rel="noopener">Portfolio</a>
      )}
      {github_profile && (
        <a href={github_profile} target="_blank" rel="noopener">GitHub</a>
      )}
      {codepen_profile && (
        <a href={codepen_profile} target="_blank" rel="noopener">CodePen</a>
      )}
    </nav>
  </div>
</section>

<style>
  .student {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(1.5rem, 3vw, 3rem) 0 2rem;
  }

  .student-poster {
    position: relative;
    background: var(--paper);
    border: 2px solid var(--ewu-red);
    box-shadow: 0 12px 20px rgba(0, 0, 0, 0.3);
    padding: 0.75rem;
    margin: 0;
    z-index: 2;
  }

  .student-back {
    position: static;
    margin-top: 0.9rem;
    margin-left: 0.2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.45rem 0.85rem;
    border: 1px solid var(--black);
    color: var(--black);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    background: var(--white);
    z-index: 4;
    transition: transform 150ms ease, background 150ms ease, color 150ms ease;
  }

  .student-back:hover,
  .student-back:focus-visible {
    background: var(--ewu-red);
    color: var(--white);
    transform: translateY(-1px);
  }

  .student-poster::before,
  .student-poster::after {
    content: "";
    position: absolute;
    top: -1.9rem;
    width: 6.1rem;
    height: 2.9rem;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    filter: drop-shadow(0 6px 8px rgba(0, 0, 0, 0.35));
    opacity: 0.98;
    z-index: 3;
  }

  .student-poster::before {
    left: -0.2rem;
    background-image: var(--tape-left);
    transform: rotate(-8deg);
  }

  .student-poster::after {
    right: -0.2rem;
    background-image: var(--tape-right);
    transform: rotate(8deg);
  }

  .student-photo {
    clip-path: var(--edge-clip, inset(0));
  }

  .student-photo img {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.25));
  }

  .student-emoji {
    font-size: 1.6rem;
  }

  .student-bio-panel {
    position: relative;
    padding: 2.2rem 2.4rem;
    background: transparent;
    color: var(--black);
    min-height: 420px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-left: -2.5rem;
    z-index: 1;
    will-change: transform, opacity;
    transform: translateX(-90px);
    opacity: 0;
    animation: bio-slide-out 620ms ease 140ms forwards;
  }

  .student-bio-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--bio-paper);
    background-size: var(--bio-paper-size, 120% 120%);
    background-repeat: no-repeat;
    background-position: center;
    filter: drop-shadow(0 10px 18px rgba(0, 0, 0, 0.25));
    z-index: -1;
  }

  @keyframes bio-slide-out {
    from {
      transform: translateX(-90px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .student-bio-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.8rem;
  }

  .student-bio-header h1 {
    text-align: left;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: clamp(1.6rem, 2vw + 1rem, 2.4rem);
  }

  .student-bio-panel p {
    font-size: 1rem;
    line-height: 1.5;
  }

  .student-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.3rem;
  }

  .student-links a {
    background: var(--white);
    border: 1px solid var(--black);
    color: var(--black);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: transform 150ms ease, background 150ms ease, color 150ms ease;
  }

  .student-links a:hover,
  .student-links a:focus-visible {
    background: var(--ewu-red);
    color: var(--white);
    transform: translateY(-1px);
  }

  @media (max-width: 840px) {
    .student {
      grid-template-columns: 1fr;
    }

    .student-links {
      justify-content: center;
    }

    .student-bio-header {
      justify-content: center;
      text-align: center;
    }

    .student-bio-header h1 {
      justify-content: center;
      text-align: center;
    }

    .student-bio-panel {
      min-height: 360px;
      margin-left: 0;
    }

    .student-back {
      margin-top: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .student-bio-panel {
      animation: none;
      transform: none;
      opacity: 1;
    }
  }
</style>