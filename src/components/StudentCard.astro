---
const {
  name,
  image,
  favorite_emoji,
  github_permalink,
  github_profile,
  codepen_profile,
  tapeLeft,
  tapeRight,
} = Astro.props;
const hasLinks = github_permalink || github_profile || codepen_profile;
const slug = name.toLowerCase().replace(/\s+/g, "-");
---

<figure
  class="poster"
  role="link"
  tabindex="0"
  aria-label={`View ${name} portfolio`}
  data-href={`/${slug}`}
  style={`--tape-left: url('${tapeLeft}'); --tape-right: url('${tapeRight}');`}
>
  <img class="poster-image" src={image} alt={name} loading="lazy" />
  <figcaption class="poster-body">
    <div class="poster-header">
      <span class="poster-emoji" aria-hidden="true">{favorite_emoji}</span>
      <h2 class="poster-name">{name}</h2>
    </div>
    {hasLinks && (
      <nav class="poster-links" aria-label={`${name} links`}>
        {github_permalink && (
          <a href={github_permalink} target="_blank" rel="noopener">Portfolio</a>
        )}
        {codepen_profile && (
          <a href={codepen_profile} target="_blank" rel="noopener">CodePen</a>
        )}
        {github_profile && (
          <a href={github_profile} target="_blank" rel="noopener">GitHub</a>
        )}
      </nav>
    )}
  </figcaption>
</figure>

<style>
  .poster {
    position: relative;
    background: var(--paper);
    border: 2px solid var(--ewu-red);
    box-shadow: 0 10px 18px rgba(0, 0, 0, 0.18), 0 0 16px rgba(183, 20, 46, 0.55);
    transition: transform 180ms ease, box-shadow 180ms ease;
    overflow: visible;
    cursor: pointer;
  }

  .poster::before,
  .poster::after {
    content: "";
    position: absolute;
    top: -1.9rem;
    width: 6.1rem;
    height: 2.9rem;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    filter: drop-shadow(0 6px 8px rgba(0, 0, 0, 0.35));
    opacity: 0.98;
    z-index: 3;
  }

  .poster::before {
    left: -0.2rem;
    background-image: var(--tape-left);
    transform: rotate(-8deg);
  }

  .poster::after {
    right: -0.2rem;
    background-image: var(--tape-right);
    transform: rotate(8deg);
  }

  .poster:hover,
  .poster:focus-within {
    transform: translateY(-4px);
    box-shadow: 0 16px 24px rgba(0, 0, 0, 0.2);
  }

  .poster-image {
    position: relative;
    z-index: 1;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-bottom: 2px solid var(--black);
  }

  .poster-body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1rem 1rem 1.2rem;
    color: var(--black);
  }

  .poster-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
  }

  .poster-emoji {
    font-size: 1.3rem;
  }

  .poster-name {
    font-family: var(--display-font);
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 800;
    text-align: center;
  }

  .poster-bio {
    font-size: 0.9rem;
    color: var(--black);
  }

  .poster-links {
    position: relative;
    z-index: 3;
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    margin-top: 0.4rem;
    justify-content: center;
  }

  .poster-links a {
    background: var(--white);
    border: 1px solid var(--black);
    color: var(--black);
    text-decoration: none;
    padding: 0.45rem 0.65rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: transform 150ms ease, background 150ms ease, color 150ms ease;
    white-space: nowrap;
  }

  @media (max-width: 560px) {
    .poster-links {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  .poster-links a:hover,
  .poster-links a:focus-visible {
    background: var(--ewu-red);
    color: var(--white);
    transform: translateY(-1px);
  }
</style>
